# Vacation Station 14 — server config template (instance: vacation-station)
#
# Copy to config.toml and fill in the password. Do NOT commit config.toml
# — it holds secrets. Only this .example file is tracked.
#
# SS14 reads [database] at startup and runs migrations automatically.
# The vs14 role must own the vacation_station database (setup.postgres.sh
# handles this).

[database]
engine = "postgres"
pg_host = "localhost"
pg_port = 5432
pg_database = "vacation_station"
pg_username = "vs14"
pg_password = "REPLACE WITH ACTUAL PASSWORD"  # from your password manager

# -----------------------------------------------------------------------------
# GAME
# -----------------------------------------------------------------------------

[game]
hostname = "Vacation Station 14"

[net]
tickrate = 30

# -----------------------------------------------------------------------------
# STATUS — HTTP status/info endpoint the launcher + hub scrape.
# -----------------------------------------------------------------------------
#
# Must bind on the same port the watchdog has configured as ApiPort for
# this instance (1212 by default — see ops/watchdog/appsettings.yml.example).
# The UDP netcode socket listens on the same port number; that's expected.

[status]
# "*:1212" = all interfaces, port 1212. Required for public reachability.
# If you reverse-proxy the status API, bind 127.0.0.1:1212 and point the
# proxy at it — but the hub needs the *advertised* URL to resolve.
bind = "*:1212"

# Tags surface on the hub; keep them short and accurate.
tags = "lang:en,region:na"

# Optional: URL the launcher opens for "Connect". Leave commented to use
# the default ss14:// scheme derived from the bind address.
# connectaddress = "ss14://play.example.com"

# -----------------------------------------------------------------------------
# HUB — advertising on the public server browser.
# -----------------------------------------------------------------------------

[hub]
# Flip to true once the server is ready for public traffic. While false,
# the server is still reachable by direct ss14:// URL but won't show up
# on the launcher.
advertise = false

# Default upstream hub. Override only if you run a private hub fork.
# hub_urls = "https://hub.spacestation14.com/"

# The URL clients use to connect back, as advertised to the hub. Leave
# commented to let the hub infer from the source IP.
# server_url = "ss14://play.example.com"

# -----------------------------------------------------------------------------
# AUTH — Wizards Den account requirement.
# -----------------------------------------------------------------------------
#
# Per Robust.Shared/Network/AuthMode.cs (Optional=0, Required=1, Disabled=2):
#   0 = Optional  — guests allowed, authenticated clients get verified
#                   identity. Good default for a new public server: lets
#                   people try before signing up, gives us a real username
#                   for admin actions. THIS VALUE.
#   1 = Required  — must be signed in with a Wizards Den account.
#                   Recommended once community is established for anti-grief.
#   2 = Disabled  — guest-only; Wizden accounts ignored. Dev / private LAN.
#
# Flipping this value requires a server restart.

[auth]
mode = 0

# -----------------------------------------------------------------------------
# METRICS — Prometheus scrape endpoint on the SS14 server.
# -----------------------------------------------------------------------------
#
# Exposes Robust.Server internals (player count, tick times, entity count,
# GC stats, etc.) on TCP 44880 for the Prometheus container in the
# ops/observability/ stack (vs-2p3). Bound to the HttpListener wildcard "*"
# (0.0.0.0 is rejected by SpaceWizards.HttpListener with "request not
# supported"). Prometheus reaches it via Docker's host-gateway alias
# (host.docker.internal). UFW scoped to the observability-stack docker
# subnet (172.18.0.0/16) — do NOT open 44880 on the public firewall.

[metrics]
enabled = true
host = "*"
port = 44880

# -----------------------------------------------------------------------------
# LOKI — log aggregation push target.
# -----------------------------------------------------------------------------
#
# Robust.Server ships Serilog.Sinks.Loki; enabling this pushes structured
# logs to the Loki container on localhost:3100 (vs-2p3). The `name` value
# is emitted as the `Server` label on every log line and MUST match the
# Prometheus `server` label in ops/observability/prometheus.yml, so that
# dashboards (vs-13x) can join logs and metrics on a single server identity.

[loki]
enabled = true
address = "http://localhost:3100"
name = "vacation-station"

# -----------------------------------------------------------------------------
# CONSOLE — first-boot admin bootstrap.
# -----------------------------------------------------------------------------

[console]
# For first-boot admin bootstrap on localhost only. Remove after
# promoting a real admin account.
# loginlocal = true
# login_host_user = "your-account"

# -----------------------------------------------------------------------------
# REPLAY — per-round recording, used as training-data source.
# -----------------------------------------------------------------------------
#
# Every round is captured to a zip (state snapshots + metadata). Recording
# machinery is loaded by engine default (server_recording_enabled = true);
# this block enables per-round auto-start + sensible sharded layout.
#
# Retention is handled out-of-band by ops/replays/rotate.sh + systemd timer.

[replay]
auto_record = true
auto_record_name = "{year}/{month}/round_{round}-{day}T{hour}{minute}Z.zip"
# Keep admin channel out of training data
record_admin_chat = false
