# Vacation Station 14 — SS14.Admin POSTGRES_PASSWORD env (vs-35d, refactored in vs-2f8.5)
#
# The populated version of this file lives at:
#   /etc/vacation-station/admin-db.env   (mode 640, owner root:ss14)
#
# NOT at ops/ss14-admin/.env (which was the old path pre-vs-2f8.5).
# Keeping secrets under /etc/vacation-station/ makes the compose file
# clone-agnostic: the same ops/ss14-admin/docker-compose.yml works
# whether you run it from /home/ubuntu/vacation-station-14/ or from
# /opt/vacation-station/ (the prod clone).
#
# Bootstrap:
#   sudo install -m 640 -o root -g ss14 /dev/null /etc/vacation-station/admin-db.env
#   sudoedit /etc/vacation-station/admin-db.env         # add POSTGRES_PASSWORD=...
#
# The companion OIDC credentials (OIDC_CLIENT_ID, OIDC_CLIENT_SECRET)
# live in /etc/vacation-station/admin-oauth.env alongside this file.
# See docs/OPERATIONS.md "SS14.Admin" for the full rotation + bootstrap
# procedure.

# Password for the vs14 postgres role owning vacation_station. Must
# match the value in your password manager + ops/observability/.env.
# See docs/OPERATIONS.md "PostgreSQL" for rotation.
POSTGRES_PASSWORD=
