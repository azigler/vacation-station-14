# Vacation Station 14 — SS14.Admin env (vs-35d)
#
# Copy to ops/ss14-admin/.env and fill in. The .env file is gitignored;
# keep the populated version out of version control.
#
#   cp ops/ss14-admin/.env.example ops/ss14-admin/.env
#   $EDITOR ops/ss14-admin/.env
#   chmod 600 ops/ss14-admin/.env
#
# The OIDC_CLIENT_ID and OIDC_CLIENT_SECRET variables do NOT go here —
# they live in /etc/vacation-station/admin-oauth.env (root:ss14, 640),
# loaded by docker-compose via `env_file:`. This file holds only the
# postgres password.

# Password for the vs14 postgres role owning vacation_station. Must
# match the value in your password manager + ops/observability/.env.
# See docs/OPERATIONS.md "PostgreSQL" for rotation.
POSTGRES_PASSWORD=
