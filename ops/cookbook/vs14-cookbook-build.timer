[Unit]
Description=Vacation Station 14 — ss14-cookbook daily rebuild timer
Documentation=file:///opt/vacation-station/docs/OPERATIONS.md

[Timer]
# 05:00 UTC every day. Off-peak vs the 03:15 UTC DB backup so the two
# timers don't fight for disk. RandomizedDelaySec spreads the start
# if multiple timers land on the same minute after a reboot catch-up.
OnCalendar=*-*-* 05:00:00 UTC
RandomizedDelaySec=15min
Persistent=true
Unit=vs14-cookbook-build.service

[Install]
WantedBy=timers.target
