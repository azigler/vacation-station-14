{
  "_comment": "VS14 Robust.Cdn config — JSON not YAML because Robust.Cdn's Program.cs only loads the ASP.NET default config sources (no AddYamlFile). Secrets (UpdateToken) come via env vars set in ops/observability/docker-compose.yml.",

  "AllowedHosts": "*",

  "BaseUrl": "https://ss14.zig.computer/cdn/",

  "Cdn": {
    "DatabaseFileName": "/database/content.db",
    "DefaultFork": "vacation-station",
    "BlobCompress": true,
    "StreamCompress": false
  },

  "Manifest": {
    "DatabaseFileName": "/database/manifest.db",
    "FileDiskPath": "/builds",
    "Forks": {
      "vacation-station": {
        "ClientZipName": "SS14.Client",
        "ServerZipName": "SS14.Server_",
        "DisplayName": "Vacation Station 14",
        "PruneBuildsDays": 90
      }
    }
  }
}
