[Unit]
Description=Vacation Station 14 — replay rotation timer
Documentation=file:///opt/vacation-station/docs/OPERATIONS.md

[Timer]
# 04:30 UTC every day — runs after the pg_dump backup at 03:15.
# Randomized delay avoids overlap if both timers fire together.
OnCalendar=*-*-* 04:30:00 UTC
RandomizedDelaySec=15min
Persistent=true
Unit=ss14-replay-rotate.service

[Install]
WantedBy=timers.target
