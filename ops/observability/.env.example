# Vacation Station 14 — Observability stack env (vs-2p3)
#
# Copy to ops/observability/.env and fill in real values. The .env file is
# gitignored; keep the populated version out of version control.
#
#   cp ops/observability/.env.example ops/observability/.env
#   $EDITOR ops/observability/.env
#
# docker-compose reads this automatically when run from ops/observability/.

# Password for the Grafana Postgres datasource. Must match the vs14 role's
# password in Postgres (see docs/OPERATIONS.md "PostgreSQL"). Store the
# canonical value in your password manager; this file is only a local copy.
POSTGRES_PASSWORD=
